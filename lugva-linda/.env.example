# Runtime database URL used by Prisma Client
DATABASE_URL=postgresql://postgres:<password>@<host>:5432/postgres

# Direct connection used by Prisma and optional migration connection
DIRECT_URL=postgresql://postgres:<password>@<host>:5432/postgres
MIGRATE_DATABASE_URL=postgresql://postgres:<password>@<host>:5432/postgres

# Supabase public client keys
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
